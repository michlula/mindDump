# Telegram Bot
TELEGRAM_BOT_TOKEN=           # Get from @BotFather on Telegram
WEBHOOK_URL=                  # Local dev only: leave empty for long-polling. On Vercel, webhook is auto-detected via /api/setup

# Supabase
SUPABASE_URL=                 # From Supabase project settings → API
SUPABASE_SERVICE_KEY=         # From Supabase project settings → API → service_role key
SUPABASE_ANON_KEY=            # From Supabase project settings → API → anon key

# Google Gemini AI
GEMINI_API_KEY=               # From https://aistudio.google.com/apikey (free)
